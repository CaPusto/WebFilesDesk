<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>

        <!-- ============================================================
             URL REWRITING — route all requests through index.php
             ============================================================ -->
        <rewrite>
            <rules>
                <!-- Allow direct access to existing files and folders -->
                <rule name="Allow static files" stopProcessing="true">
                    <match url=".*" />
                    <conditions>
                        <add input="{REQUEST_FILENAME}" matchType="IsFile" />
                    </conditions>
                    <action type="None" />
                </rule>
                <rule name="Allow existing directories" stopProcessing="true">
                    <match url=".*" />
                    <conditions>
                        <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
                    </conditions>
                    <action type="None" />
                </rule>
                <!-- Route everything else to index.php -->
                <rule name="Route to index.php" stopProcessing="true">
                    <match url=".*" />
                    <action type="Rewrite" url="index.php" />
                </rule>
            </rules>
        </rewrite>

        <!-- ============================================================
             DEFAULT DOCUMENT
             ============================================================ -->
        <defaultDocument>
            <files>
                <clear />
                <add value="index.php" />
            </files>
        </defaultDocument>

        <!-- ============================================================
             SECURITY — hide server info and block sensitive paths
             ============================================================ -->
        <httpProtocol>
            <customHeaders>
                <remove name="X-Powered-By" />
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="SAMEORIGIN" />
                <add name="X-XSS-Protection" value="1; mode=block" />
            </customHeaders>
        </httpProtocol>

        <!-- Block direct access to sensitive files -->
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="config" />
                    <add segment="vendor" />
                </hiddenSegments>
                <fileExtensions>
                    <add fileExtension=".ini" allowed="false" />
                    <add fileExtension=".log" allowed="false" />
                </fileExtensions>
            </requestFiltering>
        </security>

        <!-- ============================================================
             STATIC FILE CACHING
             ============================================================ -->
        <staticContent>
            <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
        </staticContent>

        <!-- ============================================================
             PHP SETTINGS — upload limits (adjust to match conf.ini)
             ============================================================ -->
        <!--
        <fastCgi>
            <application fullPath="C:\php\php-cgi.exe">
                <environmentVariables>
                    <environmentVariable name="PHP_FCGI_MAX_REQUESTS" value="10000" />
                </environmentVariables>
            </application>
        </fastCgi>
        -->

    </system.webServer>

    <!-- ============================================================
         PHP INI SETTINGS (IIS FastCGI)
         Uncomment and adjust as needed
         ============================================================ -->
    <!--
    <system.webServer>
        <handlers>
            <add name="PHP" path="*.php" verb="*"
                 modules="FastCgiModule"
                 scriptProcessor="C:\php\php-cgi.exe"
                 resourceType="Either" />
        </handlers>
    </system.webServer>
    -->

</configuration>
